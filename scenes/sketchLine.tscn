[sub_resource type="GDScript" id="GDScript_pgyfa"]
script/source = "extends CSGPolygon3D

@export var line_radius = 0.1: set = set_line_radius
@export var line_resoultion = 5: set = set_line_resolution


func set_line_radius(val):
	line_radius = val
	draw_polygon()

func set_line_resolution(val):
	line_resoultion = val
	draw_polygon()

func draw_polygon():
	var circle = PackedVector2Array()
	for degree in line_resoultion:
		circle.append(Vector2(
			line_radius * sin(PI * 2 * degree / line_resoultion),
			line_radius * cos(PI * 2 * degree / line_resoultion)
		))
	polygon = circle
	
func _ready():
	draw_polygon()
"

