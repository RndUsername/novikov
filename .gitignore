# ---------------------------------------------------------------------------
# Godot 4+
# ---------------------------------------------------------------------------
# Editor import/cache directory — fully regenerated on open.
.godot/
# Mono/.NET (unused now, harmless to keep ignored).
.mono/
data_*/
mono_crash.*.json
# Export output and machine-local export config (may contain paths/keys).
/builds/
/export/
export_presets.cfg

# ---------------------------------------------------------------------------
# Platform build output
# ---------------------------------------------------------------------------
/android/

# ---------------------------------------------------------------------------
# Native GDExtensions (occt, slvs)
# ---------------------------------------------------------------------------
# The compiled libraries are build artifacts produced from the *-extension
# SConstruct projects; rebuild them rather than committing them. The .gdextension
# config files are NOT ignored (see the negations below) so the project still
# knows how to load the libraries on a fresh clone.
# Ignore everything in bin/ (runtime libs, .lib/.exp/.pdb, backups), then
# re-include only the .gdextension config (and its .uid) so the project still
# knows how to load the libraries on a fresh clone.
bin/**
!bin/**/
!bin/**/*.gdextension
!bin/**/*.gdextension.uid

# ---------------------------------------------------------------------------
# Shared libraries anywhere else (e.g. addon binaries)
# ---------------------------------------------------------------------------
*.dll
*.so
*.so.*
*.dylib

# ---------------------------------------------------------------------------
# Addons
# ---------------------------------------------------------------------------
# Editor-only / installed plugins are not versioned in this project.
addons/

# ---------------------------------------------------------------------------
# Editor & OS junk
# ---------------------------------------------------------------------------
# Lock/rename leftovers (e.g. ~lib.windows....dll while the editor holds a DLL).
~*
*.tmp
*.bak
.DS_Store
Thumbs.db
desktop.ini
